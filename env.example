# ──────────────────────────────────────────────
# Trade Opportunities API — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# [REQUIRED] Google Gemini API key
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# [REQUIRED for production] Change this to a random secret string
SECRET_KEY=change-me-to-a-random-secret-string

# Rate limiting (optional — these are defaults)
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_PERIOD=60

# Session timeout in hours (default: 24)
SESSION_TIMEOUT_HOURS=24

# Max DuckDuckGo results per query (default: 10)
SEARCH_MAX_RESULTS=10

# Cache TTL in seconds — how long to cache sector data (default: 300 = 5 min)
CACHE_TTL_SECONDS=300
